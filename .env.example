# Foundry Local'ı baslattiktan sonra "foundry service status" komutuyla
# gercek adresi ve portu gorebilirsin, asagidakini ona gore guncelle.
# Port sabitlemek icin: foundry service set --port 5273
FOUNDRY_BASE_URL=http://localhost:5273/v1
# Model adini "foundry model list --downloaded" ya da http://localhost:5273/v1/models ile teyit et
FOUNDRY_MODEL=Phi-3.5-mini-instruct-generic-cpu:2
PORT=3000
